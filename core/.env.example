# IMPORTANT: This file is a template. Copy to .env and fill in real values.
# Never commit a real .env to version control. Generate secrets with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/codewarz"
SERVICE_NAME='CORE_SERVICE'

# OAuth (set in deployment; rotate immediately if leaked)
GOOGLE_CLIENT_ID="<set-in-deployment>"
GOOGLE_CLIENT_SECRET="<set-in-deployment>"
GOOGLE_REDIRECT_URI="https://codewarz.contactlikhith.me/api/v1/auth/google/callback"

# Server
PORT=3001

# Required secrets — generate fresh ones for any environment
JWT_SECRET="<required-32-byte-random-string>"
REFRESH_SECRET="<required-32-byte-random-string>"
INTERNAL_API_KEY="<required-random-string>"

# Local defaults (overridden in docker-compose)
REDIS_URL="redis://localhost:6379"
RABBITMQ_URL="amqp://codewarz:codewarz@localhost:5672"
RABBITMQ_MANAGEMENT_URL="http://localhost:15672"
