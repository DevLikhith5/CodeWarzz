# Local development template. Copy to .env and set real values.
SERVICE_NAME='LEADERBOARD_SERVICE'
PORT=3002

# Required secrets — generate fresh ones for any environment
JWT_SECRET="<required-32-byte-random-string>"
INTERNAL_API_KEY="<required-random-string>"

# Local defaults (overridden in docker-compose)
REDIS_URL="redis://localhost:6379"
RABBITMQ_URL="amqp://codewarz:codewarz@localhost:5672"
JAEGER_URL="http://localhost:14268"
LEADERBOARD_GRPC_PORT=50052
